# stock-trading-agent 环境变量模板
# ────────────────────────────────────────────────────────
# 用法:
#   1. 复制本文件为 .env  (项目根, 已被 .gitignore)
#   2. 把 <...> 占位符替换成你的真值
#   3. 重启 agent 即可生效
# ────────────────────────────────────────────────────────

# MiniMax M3 LLM (8 个调用点共用)
MINIMAX_API_KEY=<your-minimax-key>

# 飞书凭据 (6 个, mavis secret create 或直接填)
FEISHU_APP_ID=<your-feishu-app-id>
FEISHU_APP_SECRET=<your-feishu-app-secret>
FEISHU_DASH_APP_TOKEN=<your-dashboard-app-token>
FEISHU_DASH_DASHBOARD_ID=<your-dashboard-id>

# 飞书通道 (二选一或都填)
FEISHU_BITABLE_WEBHOOK=<your-bitable-webhook-url>     # 可选: 自定机器人 webhook (FEISHU_PUSH_MODE=webhook/auto 时用作 app 通道的 fallback)
FEISHU_CHAT_ID=<your-chat-id>                          # 推荐: app 模式时必填, 告诉 agent 把消息发到哪个群

# Session Fernet 加密 (可选, 留空 = 明文)
# 用 python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成
BOT_ENCRYPTION_KEY=<paste-a-fernet-key-here>

# Bot HTTP 监听 (可选, 默认 127.0.0.1:8765)
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_PORT=8765


# ─────────── 自动项 (一般不用动) ───────────
# 东方财富 ut token (东财 push2 接口公开参数, 已在代码里硬编码默认值 + 自动从东财页面刷新)
# 仅当东财轮换 ut 且自动刷新失败时才需要手动设:
# FEISHU_SINA_UT=<paste-fresh-ut-here>
# 关闭自动刷新 (用纯默认常量): UT_AUTO_REFRESH=0

# 推送通道模式 (v6, 必填):
#   app     - 强制走 OpenAPI app (要 APP_ID/SECRET/CHAT_ID)
#   webhook - 强制走 BITABLE_WEBHOOK (老的自定机器人)
#   auto    - 优先 app, 缺任一自动回退 webhook (默认, 推荐)
FEISHU_PUSH_MODE=auto
